\ufffd\ufffd\ufffd\ufffd\ufffd\ufffd\ufffd\ufffd\ufffd\ufffd\ufffd\ufffd\u01bb\ufffd\ufffd\ufffd\ufffd\ufffd\ufffd\u007fl\ufffdo\ufffd\ufffdvjy\ufffd\ufffd\ufffd\ufffd\ufffd","filename":"prev.mat","language":"Unknown"},{"binary":false,"content":"function s = entrophy_length(v)\n% computes the entrophy length.\n\n    temp = 0:255;\n    Pr = hist(v,temp);\n    Pr = Pr ./ length(v);\n    \n    % sort Pr + delete zeros\n    Pr = sort(Pr);\n    while (Pr(1) == 0)\n        Pr = Pr(:,2:end);\n        Pr = sort(Pr);\n    end\n    \n    PrLog = log2(Pr);\n    \n    Pr = Pr .* PrLog;   % Pi * log2(Pi)\n    s = sum(Pr);\n    s = -s;\nend\n\n","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__entrophy_length.m","language":"MATLAB/Objective-C"},{"binary":false,"content":"function s = hufman_length( v )\n% calc the hufman code length.\n    \n    % convert v to a vector row.\n    vecSize = 1;\n    origSize = size(size(v),2);\n    for i = 1 : origSize\n        vecSize = vecSize * size(v,i);\n    end\n    v = reshape(v,1,vecSize);\n    \n    temp = 0 : 255;\n    Pr = hist(v,temp);\n    Pr = Pr ./ length(v);\n    Pr = [Pr ; 0:length(Pr)-1];\n    Pr = Pr';   % first col Pr , second col index.\n    \n    % sort Pr + delete zeros\n    Pr = sortrows(Pr);\n    while (Pr(1) == 0)\n        Pr = Pr(2:end,:);\n        Pr = sortrows(Pr);\n    end\n\n    % we start to build a huffman tree but instead of creating a huffman\n    % code for the symbols we will count the number of merges in the tree.\n    i = 1;\n    while (Pr(1) ~= 1)\n        row1 = Pr(1,:);\n        % add the two probabiliteies with the lowest probability.\n        Pr(2) = Pr(2) + row1(1); \n        Pr = Pr(2:end,:); % delete the first row.\n        row1 = row1( :,2:end);\n        tmp = zeros(size(Pr,1),1);\n        tmp = tmp - 1;\n        Pr = [Pr tmp];\n        row2 = Pr(1, :);\n        for j = 2 : size(Pr,2)\n             if ((row2(j) == -1) && (~isempty(row1))) \n                 row2(j) = row1(1);\n                 row1 = row1( :,2:end);\n             end\n        end\n        Pr = Pr(2:end,:);  % delete the second row.\n        Pr = [row2 ; Pr];   % insert new second row. \n        row1 = Pr(1,2:end);\n        x{i} = row1;\n        i = i+1;\n        Pr = sortrows(Pr);\n    end\n    mergeNum = size(x,2);\n    HuffmanCodeLength = zeros(1,256);\n    \n    for i = 1 : mergeNum\n        tmp = x{i};\n        xSize = size(tmp,2);\n        for j= 1 : xSize\n            if (tmp(j) ~= -1)\n                HuffmanCodeLength(tmp(j)+1)=HuffmanCodeLength(tmp(j)+1)+1;\n            end\n        end\n    end\n   \n    Pr = hist(v,temp);\n    s = 0;\n    \n    % compute the length.\n    for i= 1: length(temp)\n        s = s + (Pr(i) * HuffmanCodeLength(i));\n    end\nend\n\n","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__hufman_length.m","language":"MATLAB/Objective-C"},{"binary":false,"content":"% calculates the size of the huffman code length and entropy length.\n% we needed to encode Lena256B.bmp.\n\nclear all;\npic = imread('Lena256B.bmp');\n\npicSize = size(pic,1) * size(pic,2);\nnewPic = zeros(size(pic,1),size(pic,2));\n\nfor i=1 :size(pic,1)\n    for j=1:size(pic,2)\n        newPic(i,j)=pic(i,j,1);\n    end\nend\n\nreshapedPic=reshape(newPic,1,picSize);\n\nHuffmanLength = hufman_length(reshapedPic)\nEntropyLength = entrophy_length(reshapedPic)","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__main8.m","language":"MATLAB/Objective-C"},{"binary":false,"content":"% calculates the size of the huffman code length and entropy length.\n\nclear all;\npic = imread('Lena256B.bmp');\n\npicRowSize = size(pic,1);\npicColSize = size(pic,2);\n\nv = rand(picRowSize,picColSize);\nv = floor(v * 255);\npicSize = picRowSize * picColSize;\nreshapePic = reshape(v,1,picSize);\n\nHuffmanLength=hufman_length(reshapePic)\nEntropyLength=entrophy_length(reshapePic)","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__main9.m","language":"MATLAB/Objective-C"},{"binary":true,"content":"","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__Lena256B.bmp"},{"binary":false,"content":"function s = entrophy_length(v)\n% computes the entrophy length.\n\n    temp = 0:255;\n    Pr = hist(v,temp);\n    Pr = Pr ./ length(v);\n    \n    % sort Pr + delete zeros\n    Pr = sort(Pr);\n    while (Pr(1) == 0)\n        Pr = Pr(:,2:end);\n        Pr = sort(Pr);\n    end\n    \n    PrLog = log2(Pr);\n    \n    Pr = Pr .* PrLog;   % Pi * log2(Pi)\n    s = sum(Pr);\n    s = -s;\nend\n\n","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__entrophy_length.m","language":"MATLAB/Objective-C"},{"binary":false,"content":"function s = hufman_length( v )\n% calc the hufman code length.\n    \n    % convert v to a vector row.\n    vecSize = 1;\n    origSize = size(size(v),2);\n    for i = 1 : origSize\n        vecSize = vecSize * size(v,i);\n    end\n    v = reshape(v,1,vecSize);\n    \n    temp = 0 : 255;\n    Pr = hist(v,temp);\n    Pr = Pr ./ length(v);\n    Pr = [Pr ; 0:length(Pr)-1];\n    Pr = Pr';   % first col Pr , second col index.\n    \n    % sort Pr + delete zeros\n    Pr = sortrows(Pr);\n    while (Pr(1) == 0)\n        Pr = Pr(2:end,:);\n        Pr = sortrows(Pr);\n    end\n\n    % we start to build a huffman tree but instead of creating a huffman\n    % code for the symbols we will count the number of merges in the tree.\n    i = 1;\n    while (Pr(1) ~= 1)\n        row1 = Pr(1,:);\n        % add the two probabiliteies with the lowest probability.\n        Pr(2) = Pr(2) + row1(1); \n        Pr = Pr(2:end,:); % delete the first row.\n        row1 = row1( :,2:end);\n        tmp = zeros(size(Pr,1),1);\n        tmp = tmp - 1;\n        Pr = [Pr tmp];\n        row2 = Pr(1, :);\n        for j = 2 : size(Pr,2)\n             if ((row2(j) == -1) && (~isempty(row1))) \n                 row2(j) = row1(1);\n                 row1 = row1( :,2:end);\n             end\n        end\n        Pr = Pr(2:end,:);  % delete the second row.\n        Pr = [row2 ; Pr];   % insert new second row. \n        row1 = Pr(1,2:end);\n        x{i} = row1;\n        i = i+1;\n        Pr = sortrows(Pr);\n    end\n    mergeNum = size(x,2);\n    HuffmanCodeLength = zeros(1,256);\n    \n    for i = 1 : mergeNum\n        tmp = x{i};\n        xSize = size(tmp,2);\n        for j= 1 : xSize\n            if (tmp(j) ~= -1)\n                HuffmanCodeLength(tmp(j)+1)=HuffmanCodeLength(tmp(j)+1)+1;\n            end\n        end\n    end\n   \n    Pr = hist(v,temp);\n    s = 0;\n    \n    % compute the length.\n    for i= 1: length(temp)\n        s = s + (Pr(i) * HuffmanCodeLength(i));\n    end\nend\n\n","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__hufman_length.m","language":"MATLAB/Objective-C"},{"binary":false,"content":"% calculates the size of the huffman code length and entropy length.\n% we needed to encode Lena256B.bmp.\n\nclear all;\npic = imread('Lena256B.bmp');\n\npicSize = size(pic,1) * size(pic,2);\nnewPic = zeros(size(pic,1),size(pic,2));\n\nfor i=1 :size(pic,1)\n    for j=1:size(pic,2)\n        newPic(i,j)=pic(i,j,1);\n    end\nend\n\nreshapedPic=reshape(newPic,1,picSize);\n\nHuffmanLength = hufman_length(reshapedPic)\nEntropyLength = entrophy_length(reshapedPic)","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__main8.m","language":"MATLAB/Objective-C"},{"binary":false,"content":"% calculates the size of the huffman code length and entropy length.\n\nclear all;\npic = imread('Lena256B.bmp');\n\npicRowSize = size(pic,1);\npicColSize = size(pic,2);\n\nv = rand(picRowSize,picColSize);\nv = floor(v * 255);\npicSize = picRowSize * picColSize;\nreshapePic = reshape(v,1,picSize);\n\nHuffmanLength=hufman_length(reshapePic)\nEntropyLength=entrophy_length(reshapePic)","filename":"\u00dc\u00ff\u00e9\u00eb\u00ee \u00fc\u00eb\u00dc 2 \u00e2\u00e7\u00eb\u00e6\u00dc \u00dc\u00c4\u00e0\u00c9\u00e4 \u00e0\u00f9\u00e0\u00ee__main9.m","language":"MATLAB/Objective-C"}],"languages":["MATLAB/Objective-C"],"name":"2010-07-09_unnamed","notes":"","sender":"Hila Shmuel <>","subject":"Fwd: Rest of Vegetables","summary":"This project involves implementing Huffman coding and entropy length calculation for image compression using MATLAB, specifically analyzing a sample image.","topics":["Huffman coding","image processing","MATLAB","entropy","compression techniques"]}

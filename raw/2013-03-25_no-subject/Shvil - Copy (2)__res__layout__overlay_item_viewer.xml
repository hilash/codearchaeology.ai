<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
	
	<LinearLayout
	    android:id="@+id/overlay_item_viewer_linear_layout"
	    android:layout_width="match_parent"
	    android:layout_height="wrap_content"
	    android:layout_margin="@dimen/padding_large" >

     </LinearLayout>
    
     <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFD9EAF4" >

                <TextView
                    android:id="@+id/overlay_item_viewe_like"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right|center_vertical"
                    android:layout_margin="2dp"
                    android:clickable="true"
                    android:onClick="like"
                    android:text="@string/overlay_item_viewe_like"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="#FF003050" />

                <TextView
                    android:id="@+id/overlay_item_viewe_likes_divider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right|center_vertical"
                    android:layout_margin="2dp"
                    android:text="@string/overlay_item_viewe_likes_divider"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="#FF003050" />

                <TextView
                    android:id="@+id/overlay_item_viewe_dislike"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right|center_vertical"
                    android:layout_margin="2dp"
                    android:clickable="true"
                    android:onClick="dislike"
                    android:text="@string/overlay_item_viewe_dislike"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="#FF003050" />

            </LinearLayout>
            
</LinearLayout>
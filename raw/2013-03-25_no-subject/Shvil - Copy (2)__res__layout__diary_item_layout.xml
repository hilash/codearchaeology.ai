<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical" >

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1.05"
        android:background="#FFEFF6FA" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <TextView
                android:id="@+id/diary_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/padding_medium"
                android:text="Medium Text"
                android:textAppearance="?android:attr/textAppearanceMedium" />

            <ImageView
                android:id="@+id/diary_picture"
                android:layout_width="wrap_content"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:scaleType="fitXY"
                android:src="@drawable/androidmarker" />

            <TextView
                android:id="@+id/diary_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/padding_medium"
                android:text="TextView" />

            <LinearLayout
                android:id="@+id/diary_item_player"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" >

                <ImageButton
                    android:id="@+id/diary_item_player_play"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@android:drawable/ic_media_play" />

                <ImageButton
                    android:id="@+id/diary_item_player_pause"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@android:drawable/ic_media_pause" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFD9EAF4" >

                <TextView
                    android:id="@+id/diary_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="left|center_vertical"
                    android:layout_margin="@dimen/padding_small"
                    android:layout_weight="0.20"
                    android:text="Small Text"
                    android:textAppearance="?android:attr/textAppearanceSmall" />

                <ImageButton
                    android:id="@+id/diary_delete_button"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="right"
                    android:background="@null"
                    android:src="@drawable/ic_menu_delete" />

                <ImageButton
                    android:id="@+id/diary_edit_button"
                    android:layout_width="34dp"
                    android:layout_height="29dp"
                    android:layout_gravity="right"
                    android:background="@null"
                    android:src="@drawable/ic_menu_edit" />

                <ImageButton
                    android:id="@+id/diary_share_button"
                    android:layout_width="38dp"
                    android:layout_height="33dp"
                    android:layout_gravity="right"
                    android:background="@null"
                    android:src="@drawable/ic_menu_share" />

                <ImageButton
                    android:id="@+id/diary_map_button"
                    android:layout_width="28dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="right"
                    android:layout_marginRight="@dimen/padding_small"
                    android:background="@null"
                    android:src="@drawable/ic_menu_mapmode" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
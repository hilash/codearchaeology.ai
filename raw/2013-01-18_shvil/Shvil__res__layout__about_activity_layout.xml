
    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:onClick="sendContactMail" >

        <TextView
            android:id="@+id/help_activity_layout_developer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:text="@string/about_activity_layout_developer_name"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentLeft="true"
            android:text="Credits: OpenStreetMap, Mapsforge, greenDao" />

        <TextView
            android:id="@+id/help_activity_layout_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/help_activity_layout_developer_name"
            android:layout_centerHorizontal="true"
            android:text="@string/about_activity_layout_app_name"
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imageView1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/help_activity_layout_app_name"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="27dp"
            android:baselineAlignBottom="@+id/help_activity_layout_app_picture"
            android:src="@drawable/ic_shvil" />

        <TextView
            android:id="@+id/textView1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/help_activity_layout_developer_name"
            android:layout_toLeftOf="@+id/imageView1"
            android:onClick="sendContactMail"
            android:text="@string/about_activity_layout_support"
            android:textAppearance="?android:attr/textAppearanceMedium" /><TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@+id/textView1"
        android:layout_alignBottom="@+id/textView1"
        android:layout_alignLeft="@+id/imageView1"
        android:onClick="about_activity_layout_app_name"
        android:text="@string/support_email"
        android:textAppearance="?android:attr/textAppearanceSmall" />

    </RelativeLayout>

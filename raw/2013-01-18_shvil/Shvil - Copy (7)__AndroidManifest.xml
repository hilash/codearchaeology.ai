<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.shvil.project"
    android:versionCode="1"
    android:versionName="1.0" >
    <!-- uses-permission android:name="android.permission.INTERNET"/-->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    

    <uses-sdk
        android:minSdkVersion="14"
        android:targetSdkVersion="15" />

    <application
        android:icon="@drawable/ic_shvil"
        android:label="@string/app_name"
        android:theme="@style/AppTheme" 
        android:name=".MyApplication"
        android:debuggable="true">
        
        
        <uses-library android:name="com.google.android.maps" />
        <activity
            android:name=".MainActivity"
            android:label="@string/title_activity_main" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".map.MyMapActivity"
            android:label="@string/title_activity_map" >
        </activity>
        <activity
            android:name=".menu.MyProfileActivity"
            android:label="@string/title_activity_profile" >
        </activity>
        <activity
            android:name=".menu.SettingsActivity"
            android:label="@string/title_activity_settings" >
        </activity>
        <activity
            android:name=".messages.MessagesActivity"
            android:label="@string/title_activity_messages" >
        </activity>
        <activity
            android:name=".menu.PeopleActivity"
            android:label="@string/title_activity_people" >
        </activity>
        <activity
            android:name=".angels.AngelsActivity"
            android:label="@string/title_activity_angels" >
        </activity>
        
        <activity
            android:name=".messages.RecentMessagesActivity"
            android:label="@string/title_activity_recent_messages" >
        </activity>
        
        <activity
            android:name=".diary.NoteEditor"
            android:label="@string/title_activity_note_editor" >
            
        </activity>
        
        
    		
    </application>

</manifest>